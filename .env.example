# Copy this file to .env and fill in your own values.
# .env is gitignored; .env.example is tracked as the setup reference.

# ElevenLabs voice synthesis (optional — used by tools/render-bob-sayings.py
# to generate the persona voice clips bundled in Resources/Audio/).
ELEVENLABS_API_KEY=sk_your_key_here
OLLAMABOB_VOICE_ID=your_voice_id_here

# Brave Search API (optional — enables the web_search tool).
# Without it, web_search is removed from the tool registry at launch.
# BRAVE_API_KEY=your_brave_key_here

# Jarvis Phone Service (optional — enables phone_call / phone_hangup / phone_status).
# The current daemon contract requires BOTH secrets on /call/*:
# - X-Jarvis-Key      <- JARVIS_API_KEY
# - x-operator-secret <- OPERATOR_API_SECRET
# /health is open and does not validate either secret.
# The daemon runs on localhost:3100. Without both secrets, phone tools stay out of the registry.
# JARVIS_API_KEY=your_jarvis_key_here
# OPERATOR_API_SECRET=your_operator_secret_here
